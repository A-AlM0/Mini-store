@model mini_store.ViewModels.CartItemViewModel
@{
    Layout = "_Layout";
}

<div class="container mt-4 mb-5">
    <div class="row d-flex justify-content-center align-items-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-gradient bg-primary text-white py-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="mb-0">🛒 عربة التسوق</h2>
                        <span class="badge bg-light text-primary fs-6 px-3 py-2">
                            عدد العناصر: @Model.Quantity
                        </span>
                    </div>
                </div>

                <div class="card-body p-4 text-center">
                    @if (Model.Quantity > 0)
                    {
                        <div class="row align-items-center border-bottom pb-3 mb-3 text-start">
                            <div class="col-md-6">
                                @* الانتقال لصفحة تفاصيل المنتج باستخدام الـ ProductId *@
                                <a asp-controller="Home" asp-action="Details" asp-route-id="@Model.ProductId"
                                   class="text-decoration-none text-dark">
                                    <h5 class="fw-bold mb-1">@Model.ProductName</h5>
                                </a>
                                <p class="text-muted small mb-0">سعر الوحدة: @Model.Price.ToString("C")</p>
                            </div>
                            <div class="col-md-4 text-end">
                                <span class="fw-semibold">الكمية: @Model.Quantity</span>
                                <h5 class="text-primary fw-bold mt-2">
                                    المجموع: @((Model.Price * Model.Quantity).ToString("C"))
                                </h5>
                            </div>
                            <div class="col-md-2 text-center">
                                <a asp-controller="Cart" asp-action="Remove" asp-route-id="@Model.ProductId"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> إزالة
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="py-4">
                            <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
                            <h4 class="mt-3 text-secondary">عربة التسوق فارغة حالياً</h4>
                            <p class="text-muted">تصفح المنتجات وأضف ما تحتاجه إلى السلة.</p>
                        </div>
                    }
                </div>

                <div class="card-footer bg-light p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            ⬅ مواصلة التسوق
                        </a>
                        @if (Model.Quantity > 0)
                        {
                            <button class="btn btn-success btn-lg fw-bold shadow-sm">
                                💳 إتمام عملية الشراء
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>