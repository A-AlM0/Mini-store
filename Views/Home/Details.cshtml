@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<SharedResource> SharedLocalizer

@model mini_store.Models.ProductDetails

@{
    ViewData["Title"] = "تفاصيل المنتج";
}


{

@if (TempData["SuccessMessage"] != null)
{
    <script>
        Swal.fire({
            toast: true,
            position: 'top-end',
            icon: 'success',
            text: 'تم الإضافة الى السلة بنجاح!',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true
        });
    </script>
}
<div class="container mt-4 mb-5">

    <!-- زر العودة أعلى الصفحة -->
    <div class="mb-3">
        <a asp-controller="Products" asp-action="Index" class="btn btn-link text-decoration-none ps-0">
            ⬅ العودة إلى المنتجات
        </a>
    </div>

    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-gradient bg-primary text-white py-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <h2 class="mb-0">@Model.Product.Name</h2>
                @if (Model.StockQuantity > 0)
                {
                    <span class="badge bg-success fs-6 px-3 py-2">متوفر</span>
                }
                else
                {
                    <span class="badge bg-danger fs-6 px-3 py-2">غير متوفر</span>
                }
            </div>
        </div>

        <div class="card-body p-4">
            <h3 class="text-primary fw-bold mb-4">
                @Model.Product.Price.ToString("C")
            </h3>

            <hr />

            <h5 class="mb-3 text-secondary">📋 معلومات إضافية عن المنتج</h5>

            <div class="row g-3">
                <div class="col-md-12">
                    <p class="mb-2">
                        <strong>الوصف:</strong>
                        <span class="text-muted">@Model.Description</span>
                    </p>
                </div>
                <div class="col-md-6">
                    <p class="mb-2">
                        <strong>🌍 بلد المنشأ:</strong>
                        <span class="text-muted">@Model.MadeIn</span>
                    </p>
                </div>
                <div class="col-md-6">
                    <p class="mb-2">
                        <strong>📦 الكمية المتوفرة:</strong>
                        <span class="text-muted">@Model.StockQuantity</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="card-footer bg-light p-4">
            <div class="d-flex flex-wrap gap-2 justify-content-end">
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    ⬅ العودة إلى المنتجات
                </a>

                @if (Model.StockQuantity > 0)
                {
                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.ProductId"
                       class="btn btn-success btn-lg">
                        🛒 أضف إلى السلة
                    </a>

                    <a asp-controller="Cart" asp-action="BuyNow" asp-route-id="@Model.Id"
                       class="btn btn-warning btn-lg fw-bold">
                        ⚡ الشراء الآن
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg" disabled>
                        🚫 غير متوفر حاليًا
                    </button>
                }
            </div>
        </div>
    </div>
</div>
    