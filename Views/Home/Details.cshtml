@{
    var product = ViewBag.Product;
}

<div class="container">
    <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm p-3">
                    <img src="~/images/@product.Image" class="card-img-top mb-3" style="max-height:300px; object-fit:contain;" alt="@product.Name" />
                    <div class="card-body text-center">
                        <h4 class="mb-3">@product.Name</h4>
                        <h5 class="text-success mb-3">@product.Price ريال</h5>
                        <p class="text-muted" style="font-size: 20px;">@product.Description</p>
                        <div class="mt-4 d-flex justify-content-center gap-3">
                            <a asp-action="Products" asp-route-id="@product.CategoryId" class="btn btn-outline-secondary" style="font-size: 20px; font-wight=bold;">
                                العودة إلى المنتجات
                            </a>
                            <a asp-action="AddToCart" asp-route-name="@product.Name" class="btn btn-success" style="font-size: 20px; font-wight=bold;">
                                أضف إلى السلة
                            </a>
                        </div>
                    </div>
                </div>
            </div>
    </div>
</div>