@{

}

<div dir="rtl" class="container">
<div class="row">
   @foreach (var prod in ViewBag.FilteredProducts)
{
    <div class="col-lg-4 col-md-6">
        <div class="card shadow-sm h-100 product-card">
            <img src="~/images/@prod.Image" class="card-img-top p-4" style="height:220px; object-fit:contain;" alt="@prod.Name" />
            <div class="card-body text-center">
                <h4 class="card-title fw-bold">@prod.Name</h4>
                <h5 class="text-success mb-4">@prod.Price ريال</h5>
                <a asp-action="Details" asp-route-name="@prod.Name" 
                    class="btn h5 px-4 py-2" 
                    style="background: linear-gradient(135deg, #4a0080, #9b30d0); color: white; border: none; border-radius: 20px; font-size: 20px; font-weight: bold">
                        عرض التفاصيل
                    </a> 
            </div>
        </div>
    </div>
}
</div>
</div>