@model List<mini_store.ViewModels.ApiProduct>

<h2 class="mb-4">المنتجات</h2>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="@item.Image" class="card-img-top p-3" alt="@item.Title"
                     style="height: 220px; object-fit: contain;">

                <div class="card-body d-flex flex-column">
                    <span class="badge bg-secondary mb-2 align-self-start">@item.Category</span>

                    <h5 class="card-title">@item.Title</h5>

                    <p class="card-text text-muted small flex-grow-1">
                        @(item.Description.Length > 80
                            ? item.Description.Substring(0, 80) + "..."
                            : item.Description)
                    </p>

                    <div class="mb-2">
                        @{
                            int fullStars = (int)Math.Round(item.Rating.Rate);
                        }
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="text-warning">@(i <= fullStars ? "★" : "☆")</span>
                        }
                        <small class="text-muted">(@item.Rating.Count تقييم)</small>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <span class="fw-bold text-success fs-5">$@item.Price</span>
                        <button class="btn btn-primary btn-sm">أضف للسلة</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>