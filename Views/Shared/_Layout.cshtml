<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - mini_store</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mini_store.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>
<body>
    <header>
       <nav dir="rtl" class="navbar navbar-expand-lg mb-5" style="background: linear-gradient(135deg, #4a0080, #9b30d0);">
    <div class="container">
        <a class="navbar-brand fw-bold text-white" asp-action="Index" asp-controller="Home"> <h1>متجر المتاجر</h1></a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item ms-4">
                    <a class="nav-link text-white" asp-action="Index" asp-controller="Home"><h2>الرئيسية</h2></a>
                </li>
                
                <li class="nav-item ms-4">
                    <a class="nav-link text-white" asp-action="Products" asp-controller="Home"><h2>المنتجات</h2></a>
                </li>
            </ul>

            <form class="d-flex">
                <input class="form-control me-2" type="search" placeholder="البحث" 
                       style="border: none; border-radius: 20px;">
                <button class="btn text-white" type="submit" 
                        style="background: rgba(255,255,255,0.2); border-radius: 20px;">
                    <i class="fas fa-search"></i>
                </button>
            </form>
        </div>
    </div>
</nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - mini_store - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
